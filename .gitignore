# Ignore .env files in both frontend and backend
/front-end/.env
/back-end/.env

# (Optional) also ignore example placeholders if you don’t want them tracked
/front-end/.env.local
/back-end/.env.local

/front-end/node_modules
/back-end/node_modules

/node_modules

# Database backups (contain user PII — never commit)
/.backups/